---
interface Props {
  title?: string;
}
const { title = 'Le blog de Robin' } = Astro.props;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400;9..144,600;9..144,800&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <!-- Restore saved colors before paint to avoid flash -->
  <script is:inline>
    (function() {
      var bg = localStorage.getItem('color-bg') || '#0a0a0a';
      var fg = localStorage.getItem('color-fg') || '#e8ff00';
      function hex(r,g,b){ return '#'+[r,g,b].map(function(v){return Math.round(v).toString(16).padStart(2,'0')}).join(''); }
      function parse(h){ return [parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)]; }
      function mix(a,b,t){ var p=parse(a),q=parse(b); return hex(p[0]+(q[0]-p[0])*t,p[1]+(q[1]-p[1])*t,p[2]+(q[2]-p[2])*t); }
      var s = document.documentElement.style;
      s.setProperty('--paper', bg);
      s.setProperty('--ink', fg);
      s.setProperty('--paper-soft', mix(bg, fg, 0.07));
      s.setProperty('--muted', mix(fg, bg, 0.45));
      s.setProperty('--rule', mix(bg, fg, 0.18));
      s.setProperty('--accent', fg);
    })();
  </script>
  <style>
    :root {
      --ink: #e8ff00;
      --paper: #0a0a0a;
      --paper-soft: #111111;
      --accent: #e8ff00;
      --rule: #2a2a00;
      --muted: #7f8c00;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--paper);
      color: var(--ink);
      font-family: 'Newsreader', Georgia, serif;
      font-size: 19px;
      line-height: 1.65;
      min-height: 100vh;
      transition: background 0.1s, color 0.1s;
    }
    .wrap {
      max-width: 680px;
      margin: 0 auto;
      padding: 4rem 1.5rem 6rem;
    }
    header.masthead {
      border-bottom: 2px solid var(--ink);
      padding-bottom: 1.5rem;
      margin-bottom: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    header.masthead a.brand {
      font-family: 'Fraunces', serif;
      font-weight: 800;
      font-size: 1.8rem;
      letter-spacing: -0.02em;
      color: var(--ink);
      text-decoration: none;
      font-variation-settings: "SOFT" 100;
    }
    header.masthead a.brand:hover { color: var(--accent); }
    header.masthead .subtitle {
      font-style: italic;
      color: var(--muted);
      font-size: 0.95rem;
    }
    a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
    a:hover { text-decoration-thickness: 2px; }
    h1, h2 {
      font-family: 'Fraunces', serif;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.15;
      font-variation-settings: "SOFT" 50;
    }
    footer.bottom {
      margin-top: 5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--rule);
      font-size: 0.85rem;
      color: var(--muted);
      text-align: center;
      font-style: italic;
    }
    footer.bottom a { color: var(--muted); }

    /* Floating color widget */
    #color-widget {
      position: fixed;
      bottom: 1.25rem;
      right: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--paper-soft);
      border: 1px solid var(--rule);
      border-radius: 6px;
      padding: 0.3rem 0.5rem;
      z-index: 100;
    }
    #color-widget label {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.15rem;
      font-size: 0.6rem;
      color: var(--muted);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      cursor: pointer;
    }
    #color-widget input[type=color] {
      width: 1.4rem;
      height: 1.4rem;
      border: 1px solid var(--rule);
      border-radius: 3px;
      padding: 1px;
      background: none;
      cursor: pointer;
    }
    #color-widget button {
      font-size: 0.75rem;
      color: var(--muted);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0 0.1rem;
      line-height: 1;
      align-self: flex-end;
      margin-bottom: 0.1rem;
    }
    #color-widget button:hover { color: var(--ink); }
  </style>
  <slot name="head" />
</head>
<body>
  <div class="wrap">
    <header class="masthead">
      <a href="/" class="brand">Le blog de Robin</a>
      <span class="subtitle">depuis la chambre</span>
    </header>
    <main>
      <slot />
    </main>
    <footer class="bottom">
      Écrit à la main · <a href="/admin">admin</a>
    </footer>
  </div>

  <div id="color-widget">
    <label>
      fond
      <input type="color" id="pick-bg" />
    </label>
    <label>
      texte
      <input type="color" id="pick-fg" />
    </label>
    <button id="reset-colors" title="Réinitialiser">↺</button>
  </div>

  <script>
    const root = document.documentElement;
    const pickBg = document.getElementById('pick-bg') as HTMLInputElement;
    const pickFg = document.getElementById('pick-fg') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-colors') as HTMLButtonElement;
    const DEFAULTS = { bg: '#0a0a0a', fg: '#e8ff00' };

    function parse(hex: string): [number, number, number] {
      return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
    }
    function toHex(r: number, g: number, b: number): string {
      return '#' + [r,g,b].map(v => Math.round(v).toString(16).padStart(2,'0')).join('');
    }
    function mix(a: string, b: string, t: number): string {
      const [r1,g1,b1] = parse(a), [r2,g2,b2] = parse(b);
      return toHex(r1+(r2-r1)*t, g1+(g2-g1)*t, b1+(b2-b1)*t);
    }

    function applyColors(bg: string, fg: string) {
      root.style.setProperty('--paper', bg);
      root.style.setProperty('--ink', fg);
      root.style.setProperty('--paper-soft', mix(bg, fg, 0.07));
      root.style.setProperty('--muted', mix(fg, bg, 0.45));
      root.style.setProperty('--rule', mix(bg, fg, 0.18));
      root.style.setProperty('--accent', fg);
      pickBg.value = bg;
      pickFg.value = fg;
    }

    applyColors(
      localStorage.getItem('color-bg') ?? DEFAULTS.bg,
      localStorage.getItem('color-fg') ?? DEFAULTS.fg,
    );

    pickBg.addEventListener('input', () => {
      applyColors(pickBg.value, pickFg.value);
      localStorage.setItem('color-bg', pickBg.value);
    });

    pickFg.addEventListener('input', () => {
      applyColors(pickBg.value, pickFg.value);
      localStorage.setItem('color-fg', pickFg.value);
    });

    resetBtn.addEventListener('click', () => {
      localStorage.removeItem('color-bg');
      localStorage.removeItem('color-fg');
      applyColors(DEFAULTS.bg, DEFAULTS.fg);
    });
  </script>
</body>
</html>
