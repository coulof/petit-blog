---
interface Props {
  title?: string;
}
const { title = 'Le blog de Robin' } = Astro.props;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400;9..144,600;9..144,800&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <!-- Restore saved colors before paint to avoid flash -->
  <script is:inline>
    (function() {
      const bg = localStorage.getItem('color-bg');
      const fg = localStorage.getItem('color-fg');
      if (bg) document.documentElement.style.setProperty('--paper', bg);
      if (fg) document.documentElement.style.setProperty('--ink', fg);
    })();
  </script>
  <style>
    :root {
      --ink: #e8ff00;
      --paper: #0a0a0a;
      --paper-soft: #111111;
      --accent: #ffe600;
      --rule: #2a2a00;
      --muted: #9aaa00;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--paper);
      color: var(--ink);
      font-family: 'Newsreader', Georgia, serif;
      font-size: 19px;
      line-height: 1.65;
      min-height: 100vh;
      transition: background 0.1s, color 0.1s;
    }
    .wrap {
      max-width: 680px;
      margin: 0 auto;
      padding: 4rem 1.5rem 6rem;
    }
    header.masthead {
      border-bottom: 2px solid var(--ink);
      padding-bottom: 1.5rem;
      margin-bottom: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    header.masthead a.brand {
      font-family: 'Fraunces', serif;
      font-weight: 800;
      font-size: 1.8rem;
      letter-spacing: -0.02em;
      color: var(--ink);
      text-decoration: none;
      font-variation-settings: "SOFT" 100;
    }
    header.masthead a.brand:hover { color: var(--accent); }
    header.masthead .subtitle {
      font-style: italic;
      color: var(--muted);
      font-size: 0.95rem;
    }
    a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
    a:hover { text-decoration-thickness: 2px; }
    h1, h2 {
      font-family: 'Fraunces', serif;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.15;
      font-variation-settings: "SOFT" 50;
    }
    footer.bottom {
      margin-top: 5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--rule);
      font-size: 0.85rem;
      color: var(--muted);
      text-align: center;
      font-style: italic;
    }
    footer.bottom a { color: var(--muted); }

    .color-pickers {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .color-pickers label {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.2rem;
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      cursor: pointer;
    }
    .color-pickers input[type=color] {
      width: 1.6rem;
      height: 1.6rem;
      border: 1px solid var(--rule);
      border-radius: 3px;
      padding: 1px;
      background: none;
      cursor: pointer;
    }
    .color-pickers button {
      font-size: 0.65rem;
      color: var(--muted);
      background: none;
      border: 1px solid var(--rule);
      border-radius: 3px;
      padding: 0.2rem 0.4rem;
      cursor: pointer;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      align-self: flex-end;
    }
    .color-pickers button:hover { color: var(--ink); border-color: var(--ink); }
  </style>
  <slot name="head" />
</head>
<body>
  <div class="wrap">
    <header class="masthead">
      <a href="/" class="brand">Le blog de Robin</a>
      <span class="subtitle">depuis la chambre</span>
      <div class="color-pickers">
        <label>
          fond
          <input type="color" id="pick-bg" />
        </label>
        <label>
          texte
          <input type="color" id="pick-fg" />
        </label>
        <button id="reset-colors" title="Réinitialiser">↺</button>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="bottom">
      Écrit à la main · <a href="/admin">admin</a>
    </footer>
  </div>
  <script>
    const root = document.documentElement;
    const pickBg = document.getElementById('pick-bg') as HTMLInputElement;
    const pickFg = document.getElementById('pick-fg') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-colors') as HTMLButtonElement;

    const DEFAULTS = { bg: '#0a0a0a', fg: '#e8ff00' };

    function applyColors(bg: string, fg: string) {
      root.style.setProperty('--paper', bg);
      root.style.setProperty('--ink', fg);
      pickBg.value = bg;
      pickFg.value = fg;
    }

    const savedBg = localStorage.getItem('color-bg') ?? DEFAULTS.bg;
    const savedFg = localStorage.getItem('color-fg') ?? DEFAULTS.fg;
    applyColors(savedBg, savedFg);

    pickBg.addEventListener('input', () => {
      root.style.setProperty('--paper', pickBg.value);
      localStorage.setItem('color-bg', pickBg.value);
    });

    pickFg.addEventListener('input', () => {
      root.style.setProperty('--ink', pickFg.value);
      localStorage.setItem('color-fg', pickFg.value);
    });

    resetBtn.addEventListener('click', () => {
      localStorage.removeItem('color-bg');
      localStorage.removeItem('color-fg');
      applyColors(DEFAULTS.bg, DEFAULTS.fg);
    });
  </script>
</body>
</html>
