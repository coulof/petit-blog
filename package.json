{
  "name": "petit-blog",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "db:init": "wrangler d1 execute petit-blog-db --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute petit-blog-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "astro": "^5.0.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "@types/sanitize-html": "^2.13.0",
    "wrangler": "^3.90.0"
  }
}
